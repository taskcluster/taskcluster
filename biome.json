{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**", "!**/node_modules/**", "!services/web-server/build/**",
      "!clients/client-rust/**", "!clients/client-web/build/**",
      "!clients/client-py/**", "!ui/test/e2e/**", "!.yarn/**",
      "!workers/generic-worker/**", "!clients/client/src/apis.js", "!**/*.css"
    ],
    "maxSize": 5242880
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "single",
      "trailingCommas": "all",
      "bracketSpacing": true
    }
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "correctness": {
        "noUnusedVariables": "warn",
        "noSwitchDeclarations": "error",
        "noUnreachable": "error",
        "noConstantCondition": "off",
        "noUnusedFunctionParameters": "warn",
        "noUnusedImports": "error",
        "useParseIntRadix": "warn",
        "noConstructorReturn": "off",
        "useYield": "off",
        "noUnsafeFinally": "off",
        "noUnknownTypeSelector": "off",
        "noUnknownProperty": "off",
        "noUnsafeOptionalChaining": "error",
        "useJsxKeyInIterable": "error"
      },

      "security": {
        "noGlobalEval": "error",
        "noDangerouslySetInnerHtml": "error"
      },

      "suspicious": {
        "noDoubleEquals": "error",
        "noVar": "error",
        "noConsole": "off",
        "noMisleadingCharacterClass": "off",
        "noUselessEscapeInString": "off",
        "noExplicitAny": "off",
        "noThenProperty": "off",
        "useIsArray": "warn",
        "noTemplateCurlyInString": "warn",
        "noAssignInExpressions": "warn",
        "noPrototypeBuiltins": "warn",
        "noTsIgnore": "off",
        "noGlobalIsNan": "warn",
        "noGlobalIsFinite": "warn",
        "noShadowRestrictedNames": "off",
        "noDuplicateProperties": "off",
        "noControlCharactersInRegex": "off",
        "noConfusingVoidType": "off",
        "useIterableCallbackReturn": "off",
        "noDuplicateFields": "error"
      },

      "style": {
        "useCollapsedElseIf": "error",
        "useBlockStatements": "error",
        "useConst": "error",
        "useNodejsImportProtocol": "error",
        "useTemplate": "error",
        "useExponentiationOperator": "error",
        "noDescendingSpecificity": "off"
      },

      "a11y": {
        "noSvgWithoutTitle": "error",
        "useSemanticElements": "error",
        "useAltText": "error"
      },

      "performance": {
        "noAccumulatingSpread": "off"
      },

      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 60
          }
        },
        "noUselessEscapeInRegex": "off",
        "useArrowFunction": "off",
        "useLiteralKeys": "error",
        "useDateNow": "error",
        "useOptionalChain": "error",
        "noImportantStyles": "off",
        "noBannedTypes": "off",
        "noArguments": "warn",
        "useRegexLiterals": "error",
        "noUselessUndefinedInitialization": "off",
        "noCommaOperator": "warn",
        "noUselessTernary": "error",
        "noUselessConstructor": "error",
        "useIndexOf": "error",
        "noUselessThisAlias": "off",
        "noUselessContinue": "error",
        "noStaticOnlyClass": "off",
        "useFlatMap": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["ui/src/**"],
      "linter": {
        "rules": {
          "correctness": {
            "useHookAtTopLevel": "error",
            "useExhaustiveDependencies": "warn"
          },
          "suspicious": {
            "noConsole": "error",
            "noVar": "off"
          },
          "style": {
            "useCollapsedElseIf": "off",
            "useBlockStatements": "off"
          },
          "a11y": {
            "useValidAnchor": "error",
            "noStaticElementInteractions": "off",
            "useKeyWithClickEvents": "off"
          },
          "complexity": {
            "noUselessFragments": "off"
          }
        }
      }
    }
  ]
}
